# Google AI (Gemini) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override model (default: gemini-2.5-flash — matches AI Studio "Gemini 2.5 Flash"; fallbacks if missing)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: keep requests small on free tier (TPM / RPD)
# GEMINI_CHAT_MAX_MESSAGES=16
# GEMINI_MAX_MESSAGE_CHARS=12000
# GEMINI_MAX_OUTPUT_TOKENS=2048
